terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
  }

  # Bootstrap: state local neste diretório (não usar este bucket como backend de si mesmo).
}

provider "aws" {
  region = var.aws_region
}
