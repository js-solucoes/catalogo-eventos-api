{
  "name": "catalogo-eventos-api",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "nodemon",
    "build:clean": "yarn clear:packages && yarn build",
    "clear:packages": "rimraf dist && rimraf tsconfig.tsbuildinfo && rimraf node_modules && yarn install",
    "build": "NODE_ENV=production tsc -p tsconfig.json && tsc-alias -p tsconfig.json && yarn copy:src/core/docs",
    "start": "node dist/server.js",
    "start:debug": "node --inspect dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint src",
    "lint:ci": "eslint src",
    "copy:swagger": "copyfiles -u 2 \"src/docs/**/*\" dist/docs",
    "copy:src/core/docs": "copyfiles -u 1 \"src/core/docs/**/*\" dist",
    "test": "NODE_ENV=test jest --passWithNoTests --silent --noStackTrace --runInBand",
    "test:verbose": "NODE_ENV=test jest --passWithNoTests --runInBand",
    "test:clear": "yarn exec jest --clearCache",
    "test:unit": "yarn test -- --watchAll -c jest-unit-config.ts",
    "test:integration": "yarn test -- --watchAll -c jest-integration-config.js",
    "test:staged": "yarn test -- --findRelatedTests",
    "test:ci": "yarn test -- --coverage",
    "smoke:http": "node scripts/smoke-http.cjs",
    "smoke:alb": "node scripts/smoke-alb.cjs",
    "deploy:ecr": "bash scripts/ecr-build-push.sh",
    "deploy:ecs:roll": "bash scripts/ecs-force-new-deployment.sh",
    "verify:aurora-db": "node scripts/verify-aurora-db.cjs",
    "check": "yarn typecheck && yarn format:check && yarn lint && yarn test:ci",
    "db:migrate": "node scripts/sequelize-with-node-env.cjs db:migrate",
    "db:migrate:undo": "node scripts/sequelize-with-node-env.cjs db:migrate:undo",
    "db:migrate:status": "node scripts/sequelize-with-node-env.cjs db:migrate:status",
    "db:seed": "node scripts/sequelize-with-node-env.cjs db:seed:all",
    "db:seed:undo": "node scripts/sequelize-with-node-env.cjs db:seed:undo:all",
    "db:bootstrap": "yarn db:migrate && yarn db:seed",
    "verify:dist": "node scripts/verify-dist.cjs",
    "check:rds-ca": "node scripts/check-rds-ca-path.cjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "copyfiles": "^2.4.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "sqlite3": "^5.1.7",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "bcrypt": "^6.0.0",
    "deepmerge": "^4.3.1",
    "dotenv": "^17.4.1",
    "express": "^5.1.0",
    "fast-glob": "^3.3.3",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "mysql2": "^3.14.1",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "sharp": "^0.33.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0",
    "zod": "^4.1.12"
  },
  "_moduleAliases": {
    "@": "dist"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "test/**/*.ts": [
      "prettier --write"
    ]
  }
}
