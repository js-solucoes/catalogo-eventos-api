# APP
NODE_ENV=development
PORT=3000
API_VERSION=v1
SWAGGER_ENABLED=true

# SECURITY
# Em produção, defina origens permitidas (separadas por vírgula). Lista vazia bloqueia browsers com Origin.
# CORS_ORIGINS=https://app.exemplo.com,https://admin.exemplo.com
JWT_SECRET=ffddb3759aca70db2ee91963cee26082a8bf46903e37baf5624962f5e9035170
JWT_ACCESS_SECRET=ffddb3759aca70db2ee91963cee26082a8bf46903e37baf5624962f5e9035170
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=sua_chave_secreta_para_refresh_token
JWT_REFRESH_EXPIRES_IN=7d
SALT=10
UPDATE_MODEL=true
# Seed do admin (obrigatórios para db:seed). Em produção use segredos reais.
ADMIN_EMAIL=admin@catalogo-eventos.com.br
ADMIN_PASSWORD=admin123

# DB (Aurora MySQL: use o endpoint do writer; em ECS/Fargate defina DB_SSL=true)
DB_DIALECT=mysql
# Cliente MySQL: use 127.0.0.1 ou localhost com docker-compose.mysql.yml — NÃO use 0.0.0.0 (ECONNREFUSED).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_app
DB_USERNAME=user_app
DB_PASSWORD=Senha@123
DB_NAME=projeto_basico_com_crud_usuario
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# Aurora/RDS com TLS: baixe o bundle e aponte o caminho (migrate/seed usam este arquivo)
# curl -fsSL -o certs/rds-global-bundle.pem https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# DB_SSL_CA_PATH=certs/rds-global-bundle.pem
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

# AWS
MEDIA_STORAGE=s3
S3_BUCKET=your-s3-bucket-name
AWS_REGION=your-aws-region
# URL pública do bucket (ou CloudFront) para montar links de objetos em public/*
S3_PUBLIC_BASE_URL=https://your-s3-bucket-name.s3.amazonaws.com/
# Prefixo lógico para objetos públicos (default: public)
# S3_PUBLIC_PREFIX=public
# Classe de armazenamento (ex.: INTELLIGENT_TIERING para custo variável)
# S3_STORAGE_CLASS=INTELLIGENT_TIERING
# Opcional: sobrescreve base pública das URLs de mídia
# PUBLIC_MEDIA_BASE_URL=https://cdn.exemplo.com
# WEB_IMAGE_MAX_WIDTH=1920
# WEB_IMAGE_MAX_HEIGHT=1080
# WEB_IMAGE_WEBP_QUALITY=82

DB_SSL=true
# RDS/Aurora: deixe vazio para perfil "Amazon RDS" do mysql2. Só defina DB_SSL_CA_PATH se precisar de PEM customizado.
# DB_SSL_CA_PATH=certs/rds-global-bundle.pem
DB_SSL_REJECT_UNAUTHORIZED=true